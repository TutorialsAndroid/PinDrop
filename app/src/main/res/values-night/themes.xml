<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PinDrop" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary_night</item>
        <item name="colorPrimaryVariant">@color/primaryVariant_night</item>
        <item name="colorOnPrimary">@color/onPrimary_night</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary_night</item>
        <item name="colorSecondaryVariant">@color/secondary_night</item>
        <item name="colorOnSecondary">@color/onSecondary_night</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_night</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface_night</item>
        <item name="colorOnSurface">@color/onSurface_night</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primaryVariant_night</item>
    </style>
</resources>